# ─────────────────────────────────────────────────────────────────────────────
# POLYTRACK — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Trading Wallet (required for real auto-copy trades) ───────────────────────
# Your Ethereum private key for signing orders via EIP-712
# ⚠️  KEEP THIS SECRET — never commit to git
PRIVATE_KEY=

# Your Polymarket proxy wallet address (shown in Polymarket UI under "Deposit Address")
# This is the address that holds your USDC on Polygon
FUNDER_ADDRESS=

# ── Polymarket API Credentials (optional, for authenticated endpoints) ─────────
# Generate at: https://polymarket.com → Settings → API
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=

# ── Auto-copy Settings ────────────────────────────────────────────────────────
# Maximum USDC to spend per auto-trade
MAX_TRADE_USDC=100

# Number of ELITE wallets that must agree to trigger auto-copy (≥3 recommended)
MIN_WALLETS=3

# How often to refresh wallet positions (seconds)
SCAN_INTERVAL=60

# ── Additional Wallets to Watch (comma-separated, no spaces) ──────────────────
# Add any specific wallet addresses you want to always track
WATCH_WALLETS=0xYourWallet1,0xYourWallet2
