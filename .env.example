# ─────────────────────────────────────────────────────────────────────────────
# POLYTRACK v2 — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
# Bind address. Default 127.0.0.1 keeps the dashboard reachable only via SSH
# tunnel / Tailscale. Use 0.0.0.0 only if you have a firewall in front.
HOST=127.0.0.1

# Disable the Polymarket WebSocket relay. Useful when the upstream WS
# endpoint is misbehaving — the 60s scan loop still drives all data
# capture, you just lose sub-second dashboard updates.
POLY_WS_DISABLE=false

# ── Security ──────────────────────────────────────────────────────────────────
# Secret used to sign JWTs issued by /auth/login. Must be at least 16 chars.
# Required when NODE_ENV=production — server crashes at boot if unset.
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Bootstrap your first admin (after JWT_SECRET is set):
#   node scripts/create-admin.js <username> <password>
# Subsequent users register via /auth/register with an invite link from
# /auth/invite (admin only).

# Comma-separated list of allowed CORS origins
# Use * for development only
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Trading Wallet (required for real auto-copy trades) ───────────────────────
# Your Ethereum private key for signing orders via EIP-712
# ⚠️  KEEP THIS SECRET — never commit to git
PRIVATE_KEY=

# Your Polymarket proxy wallet address (shown in Polymarket UI under "Deposit Address")
FUNDER_ADDRESS=

# ── Polymarket L2 API Credentials (REQUIRED for live trading) ─────────────────
# Polymarket CLOB requires HMAC-SHA256 auth on every order request.
# After you've set PRIVATE_KEY above, generate these three values with:
#
#   node scripts/derive-api-key.js --env >> .env
#
# The script signs an EIP-712 ClobAuth payload with your PRIVATE_KEY and calls
# GET /auth/derive-api-key. The returned triple is stable — re-running returns
# the same values. Treat POLY_API_SECRET like a password; never commit this file.
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=

# ── CLOB V2 Migration (cutover 2026-04-22 ~11:00 UTC) ─────────────────────────
# pUSD is the new collateral token (replaces USDC.e). Leave blank until
# Polymarket publishes the canonical Polygon address on docs.polymarket.com/resources/contracts
PUSD_ADDRESS=

# Optional builder attribution code (from polymarket.com/settings?tab=builder).
# Leave blank to sign orders with a zero builder field (no attribution/rev-share).
POLY_BUILDER_CODE=

# Override CLOB host for V2 testing (e.g. https://clob-v2.polymarket.com).
# Leave blank to use production clob.polymarket.com.
POLY_CLOB_URL=

# Polymarket signature scheme.
#   0 — EOA (self-custody, signer IS the maker)
#   1 — POLY_PROXY (Magic email / Google / social login) — DEFAULT, most common
#   2 — POLY_GNOSIS_SAFE (newer Safe-based proxy, some MetaMask accounts)
# Verify by opening polymarket.com → place $1 order → DevTools → Network → POST /order
# → inspect the `signatureType` field in the request payload.
POLY_SIGNATURE_TYPE=1

# ── Auto-copy Settings ────────────────────────────────────────────────────────
# Maximum USDC to spend per auto-trade
MAX_TRADE_USDC=100

# Slippage tolerance for limit orders (percentage)
SLIPPAGE_PCT=2

# Number of ELITE wallets that must agree to trigger signal (≥3 recommended)
MIN_WALLETS=3

# How often to refresh wallet positions (seconds)
SCAN_INTERVAL=60

# ── Wallets to Watch (comma-separated) ────────────────────────────────────────
WATCH_WALLETS=
